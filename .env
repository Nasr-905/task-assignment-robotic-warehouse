# ------- TARWARE Environment Settings -------
# Options: tiny, small, medium, large, extralarge
TARWARE_SIZE=extralarge
# Must be an integer
TARWARE_AGVS=3
# Options: partial, global
TARWARE_OBS_TYPE=partial

# ------- TARWARE Simulation Settings -------
# Must be an integer
TARWARE_STEPS=10000

# ------- Classical Baseline Defaults -------
# Must be an integer
TARWARE_CLASSICAL_EPISODES=1

# ------- RL Training Defaults -------
# Must be an integer
TARWARE_RL_TOTAL_TIMESTEPS=100000
# Must be a float
TARWARE_RL_LEARNING_RATE=0.0003
# Must be a float in [0, 1]
TARWARE_RL_GAMMA=0.99
# Options: sum, mean
TARWARE_REWARD_AGGREGATION=sum
# Path for saving/loading RL models
TARWARE_MODEL_PATH=models/tarware_ppo

# ------- RL Evaluation Defaults -------
# Must be an integer
TARWARE_RL_EVAL_EPISODES=5
# Options: true, false
TARWARE_DETERMINISTIC=false
# Must be a float (seconds)
TARWARE_RENDER_SLEEP=0.5
# Options: true, false
TARWARE_ENABLE_ENV_CHECKER=false

# ------- General Settings -------
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
TARWARE_LOG_LEVEL=INFO
# Must be an integer
TARWARE_SEED=21