# ------- TARWARE Environment Settings -------
# Options: tiny_dhl, small_dhl, medium_dhl, large_dhl, fill_dhl (must correspond to a CSV file in data/maps/shelves)
TARWARE_MAP_NAME="large_dhl"
# Options: order_data_sample, order_data_full (must correspond to a CSV file in data/processed)
TARWARE_ORDER_DATA="generated_orders"
# Must be an integer
TARWARE_AGVS=12
# Must be an integer
TARWARE_PICKERS=4
# Options: partial, global
TARWARE_OBS_TYPE=partial
# Must be an integer
TARWARE_REQUEST_QUEUE_SIZE=20
# Must be a float (seconds)
TARWARE_STEPS_PER_SIMULATED_SECOND=1.0
# Must be an integer
TARWARE_MAX_STEPS=10800
# Options: global, individual, two_stage
TARWARE_REWARD_TYPE=global

# ------- Rendering Defaults -------
# Must be an integer
TARWARE_RENDER_WIDTH=1680
# Must be an integer
TARWARE_RENDER_HEIGHT=1050

# ------- Classical Baseline Defaults -------
# Must be an integer
TARWARE_CLASSICAL_EPISODES=1

# ------- RL Training Defaults -------
# Must be an integer
TARWARE_RL_TOTAL_TIMESTEPS=100000
# Must be a float
TARWARE_RL_LEARNING_RATE=0.0003
# Must be a float in [0, 1]
TARWARE_RL_GAMMA=0.99
# Options: sum, mean
TARWARE_REWARD_AGGREGATION=sum
# Path for saving/loading RL models
TARWARE_MODEL_PATH=models/tarware_ppo

# ------- RL Evaluation Defaults -------
# Must be an integer
TARWARE_RL_EVAL_EPISODES=5
# Options: true, false
TARWARE_DETERMINISTIC=false
# Must be a float (seconds)
TARWARE_RENDER_SLEEP=0.5
# Options: true, false
TARWARE_ENABLE_ENV_CHECKER=false

# ------- General Settings -------
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
TARWARE_LOG_LEVEL=DEBUG
# Must be an integer
TARWARE_SEED=21

# ------- Physical Time & Human Factors -------
# Real-world seconds represented by one simulated second.
TARWARE_REAL_SECONDS_PER_SIM_SECOND=1.0
# Physical cell size for future AGV speed modeling.
TARWARE_GRID_CELL_SIZE_M=1.0
# Future AGV speed reference in meters per second.
TARWARE_AGV_NOMINAL_SPEED_M_S=1.0

# Enable/disable human factors subsystem.
TARWARE_HF_ENABLED=1
# Default picker effort preset per warehouse: low, medium, high.
TARWARE_HF_DEFAULT_PROFILE=medium
# Optional JSON map-level default override, e.g. {"tiny_dhl":"low","large":"high"}
TARWARE_HF_DEFAULT_PROFILE_BY_MAP={}
# Optional JSON per-picker override by picker spawn index, e.g. {"0":"high","2":"low"}
TARWARE_HF_PICKER_PROFILE_OVERRIDES={}

# Fatigue bounds.
TARWARE_HF_FATIGUE_MIN=0.0
TARWARE_HF_FATIGUE_MAX=100.0

# Pick timing in physical simulated seconds.
TARWARE_PICK_BASE_SECONDS=3.0
TARWARE_PICK_UNIT_CUBE_SECONDS_SCALE=1.0
TARWARE_PICK_QUANTITY_EXTRA_SECONDS=1.0

# Optional JSON profile overrides.
# TARWARE_HF_PROFILE_LOW={"metabolic_rate_idle":0.8,"metabolic_rate_walking":2.0,"metabolic_rate_picking":2.4}
# TARWARE_HF_PROFILE_MEDIUM={"metabolic_rate_idle":1.0,"metabolic_rate_walking":2.6,"metabolic_rate_picking":3.0}
# TARWARE_HF_PROFILE_HIGH={"metabolic_rate_idle":1.2,"metabolic_rate_walking":3.2,"metabolic_rate_picking":3.8}
